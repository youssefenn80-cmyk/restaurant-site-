<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>أيقونة تطبيق أنيقة</title>
  <!-- Font Awesome للأيقونات -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background: linear-gradient(135deg, #6a11cb, #2575fc);
      margin: 0;
      font-family: Arial, sans-serif;
    }
    .app-icon {
      font-size: 150px;       /* أيقونة كبيرة */
      color: #fff;             /* لون أيقونة أبيض */
      background: linear-gradient(45deg, #ff6b6b, #feca57);
      padding: 30px;
      border-radius: 30px;    /* شكل دائري/مربع بزوايا منحنية */
      box-shadow: 0 15px 25px rgba(0,0,0,0.3), 0 5px 10px rgba(0,0,0,0.2);
      transition: transform 0.4s, box-shadow 0.4s;
    }
    .app-icon:hover {
      transform: scale(1.2) rotate(15deg);
      box-shadow: 0 25px 35px rgba(0,0,0,0.4), 0 10px 15px rgba(0,0,0,0.25);
      cursor: pointer;
    }
  </style>
</head>
<body>
  <!-- أيقونة مثل أي تطبيق -->
  <i class="fas fa-rocket app-icon"></i>
</body>
</html>
